# Backend .env.example for SocialSphere
# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/socialsphere
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/socialsphere

# JWT
JWT_SECRET=your-super-secret-jwt-key-here-make-it-very-long-and-random
JWT_EXPIRE=30d

# Cloudinary (Required for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Client URL (Frontend origin for CORS/Socket.IO)
CLIENT_URL=http://localhost:5173

# Rate Limiting (Optional)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=200

# Email (Optional - if implementing email verification)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
